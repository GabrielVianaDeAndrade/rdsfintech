# Ambiente
NODE_ENV=development
PORT=4000

# Origem permitida para CORS (domínio do frontend em produção)
CORS_ORIGIN=https://app.rdsfintech.com.br

# JWT — tokens de curta duração + refresh token
JWT_ACCESS_SECRET=troque-por-um-segredo-forte-de-32-bytes
JWT_REFRESH_SECRET=troque-por-outro-segredo-forte-de-32-bytes
JWT_ACCESS_EXPIRES_IN=10m
JWT_REFRESH_EXPIRES_IN=7d

# Chave de criptografia AES-256-GCM para campos sensíveis (32 bytes em base64)
FIELD_ENCRYPTION_KEY=base64:troque-por-32-bytes-aleatorios-em-base64

# CSRF
CSRF_SECRET=troque-por-um-segredo-csrf

# Provedor BaaS (Banking as a Service) externo
BAAS_BASE_URL=https://sandbox.provedor-baas.com.br/v1
BAAS_CLIENT_ID=
BAAS_CLIENT_SECRET=
BAAS_WEBHOOK_SECRET=

# AWS / DynamoDB (credenciais reais via IAM Role da instância EC2 em produção)
AWS_REGION=sa-east-1
DYNAMODB_TABLE_NAME=rdsfintech-core
